			if Alpha <= 0 then
				BaseNotification:Remove(BaseNotification.Object)
			end
		end
		return BaseNotification
	end
	local notifs = {}
	function notification:Create(Text, Duration)
		notifs[#notifs + 1] = CreateBase(Text, Duration)
	end
	function notification.Update(dt)
		for k = 1, #notifs do
			local v = notifs[k]
			if v and not v.IsAlive then
				TableRemove(notifs, k)
			end
		end
		local length = #notifs
		for i = 1, #notifs do
			local note = notifs[i]
			note:Update(i, length, dt)
			if tick() - note.Time >= note.Duration then
				note:Fade(length, dt)
				note.fading = true
			end
		end
	end
	RunService.RenderStepped:Connect(notification.Update)
	notification:Create("welcome user.", 10)
end
