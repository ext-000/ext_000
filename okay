	function ContextMenu.new(Object, mode)
		local self = setmetatable({}, ContextMenu)
		self.objects = {}
		self.mode = mode or "select"
		self.cache = {}
		local ContextMenuObjects = CreateInstance("Frame", {
			Name = "ContextMenu",
