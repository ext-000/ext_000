			Visible = false,
			AutomaticSize = Enum.AutomaticSize.Y,
			Parent = Object,
			["Children"] = CreateInstance("UIListLayout", {
				SortOrder = Enum.SortOrder.LayoutOrder,
				FillDirection = Enum.FillDirection.Vertical,
				Padding = UDimNew(0, 0),
			}),
		})
		self.container = ContextMenuObjects
		local function UpdateSize()
			local MinWidth = 60
			for i, label in next, ContextMenuObjects:GetChildren() do
				if label:IsA("TextButton") then
					MinWidth = MathMax(MinWidth, label.TextBounds.X)
				end
			end
			ContextMenuObjects.Size = GVector2New(MinWidth + 8, ContextMenuObjects.UIListLayout.AbsoluteContentSize.Y)
		end
		ContextMenuObjects.UIListLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(UpdateSize)
		TaskSpawn(UpdateSize)
		local function open()
			for i, v in pairs(Library.OpenFrames) do
				i.Visible = false
				Library.OpenFrames[i] = nil
			end
			Library.OpenFrames[ContextMenuObjects] = true
			ContextMenuObjects.Visible = true
		end
		local function close()
			Library.OpenFrames[ContextMenuObjects] = nil
			ContextMenuObjects.Visible = false
		end
		self.close = close
		local db = false
		Object.MouseButton2Click:Connect(function()
			if not db then
				db = true
				if ContextMenuObjects.Visible then
					close()
				else
					open()
				end
				db = false
			end
		end)
		UserInputService.InputBegan:Connect(function(input)
			if input.UserInputType == Enum.UserInputType.MouseButton1 and ContextMenuObjects.Visible then
				if not IsMouseOverFrame(Object) and not IsMouseOverFrame(ContextMenuObjects) then
					close()
				end
			end
		end)
		return self
	end
	function ContextMenu:addOption(option_name, callback)
		local TempTable, _, OptionObject = gpm.AddButton({
			Text = option_name,
			Callback = callback,
		}, self.container, true)
		SetZIndexValue(OptionObject, 3)
		local function unclick()
			OptionObject.TextColor3 = Color3RGB(120, 120, 120)
		end
		local db = false
		local function click()
			if not db then
				db = true
				for i, v in self.objects do
					v.unclick()
				end
				callback(option_name)
				OptionObject.TextColor3 = Color3RGB(255, 255, 255)
				if self.mode == "click" then
					Sleep(0.1)
					unclick()
					db = false
				else
					db = false
				end
			end
		end
		OptionObject.MouseButton1Click:Connect(click)
		self.objects[option_name] = {
			click = click,
			unclick = unclick,
		}
	end
	function ContextMenu:selectOption(option_name)
		for i, v in self.objects do
			v.unclick()
		end
		if self.objects[option_name] then
			self.objects[option_name].click()
		end
	end
end
